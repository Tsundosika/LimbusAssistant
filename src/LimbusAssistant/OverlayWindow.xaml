<Window x:Class="Tsundosika.LimbusAssistant.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Limbus Assistant Overlay"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ShowActivated="False"
        ResizeMode="NoResize">
    <Canvas x:Name="OverlayCanvas">
        <Rectangle x:Name="ReadOutline"
                   StrokeThickness="2"
                   RadiusX="4"
                   RadiusY="4"
                   Visibility="Collapsed"/>
        <Border x:Name="VerdictPanel"
                Background="#E6101018"
                BorderBrush="#88D9A441"
                BorderThickness="1"
                CornerRadius="10"
                Padding="14,10"
                MinWidth="250"
                MaxWidth="340"
                Visibility="Collapsed">
            <StackPanel>
                <TextBlock x:Name="HeadlineText"
                           FontSize="20"
                           FontWeight="Bold"
                           Foreground="White"/>
                <TextBlock x:Name="KitText"
                           FontSize="14"
                           Foreground="#FFE8ECF8"
                           Margin="0,4,0,0"
                           TextWrapping="Wrap"/>
                <TextBlock x:Name="SanityText"
                           FontSize="12"
                           Foreground="#FFB8C0D8"
                           Margin="0,4,0,0"/>
                <TextBlock x:Name="ActionText"
                           FontSize="12"
                           Foreground="#FF9AA0B4"
                           Margin="0,6,0,0"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>
        <Border x:Name="IdleChip"
                Background="#B3101018"
                BorderBrush="#44D9A441"
                BorderThickness="1"
                CornerRadius="12"
                Padding="10,4"
                Visibility="Collapsed">
            <TextBlock x:Name="IdleChipText"
                       FontSize="11"
                       Foreground="#FF9AA0B4"
                       Text="watching for your next move"/>
        </Border>
    </Canvas>
</Window>
