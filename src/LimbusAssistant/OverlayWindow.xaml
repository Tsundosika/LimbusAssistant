<Window x:Class="Tsundosika.LimbusAssistant.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Limbus Assistant Overlay"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ShowActivated="False"
        ResizeMode="NoResize">
    <Grid>
        <Border HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="24"
                Background="#D9101018"
                BorderBrush="#66D9A441"
                BorderThickness="1"
                CornerRadius="10"
                Padding="14"
                MinWidth="250">
            <StackPanel>
                <TextBlock Text="LIMBUS ASSISTANT"
                           Foreground="#FFD9A441"
                           FontWeight="Bold"
                           FontSize="12"/>
                <TextBlock x:Name="StatusText"
                           Foreground="#FF9AA0B4"
                           FontSize="11"
                           Margin="0,2,0,8"/>
                <TextBlock x:Name="WinRateText"
                           Foreground="White"
                           FontSize="28"
                           FontWeight="Bold"
                           Text="…"/>
                <TextBlock x:Name="VerdictText"
                           Foreground="#FFB8C0D8"
                           FontSize="14"
                           FontWeight="Bold"/>
                <TextBlock x:Name="DamageText"
                           Foreground="#FFB8C0D8"
                           FontSize="13"/>
                <TextBlock x:Name="SourceText"
                           Foreground="#FF707890"
                           FontSize="10"
                           Margin="0,6,0,0"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
